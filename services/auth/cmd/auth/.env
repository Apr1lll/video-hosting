# App
APP_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=postgres
DB_SSL_MODE=disable
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT=5m

# Server
SERVER_PORT=8080
SERVER_READ_TIMEOUT=15s
SERVER_WRITE_TIMEOUT=15s
SERVER_IDLE_TIMEOUT=60s

# JWT
JWT_PRIVATE_KEY_PATH=../../internal/keys/private.pem
JWT_PUBLIC_KEY_PATH=../../internal/keys/public.pem
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=168h
JWT_ISSUER=auth-service